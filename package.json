{
  "name": "monorepo-template-generator",
  "private": true,
  "type": "module",
  "bin": {
    "monofactory": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "init:blueprint": "bun src/index.ts init",
    "plan": "bun src/index.ts plan",
    "apply": "bun src/index.ts apply",
    "doctor": "bun src/index.ts doctor"
  },
  "dependencies": {
    "prompts": "^2.4.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3"
  }
}
